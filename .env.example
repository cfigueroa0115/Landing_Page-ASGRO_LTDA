# ==============================================================================
# ASGRO Landing Page - Environment Variables
# ==============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED — Always
# ------------------------------------------------------------------------------

# Neon PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/asgro?sslmode=require"

# WhatsApp business phone number (with country code, no spaces or symbols)
# Example: 573001234567 (Colombia +57)
NEXT_PUBLIC_WHATSAPP_NUMBER="573001234567"

# ------------------------------------------------------------------------------
# REQUIRED IN PRODUCTION — Optional in development
# (In development, if empty/missing, UI hides corresponding contact sections)
# ------------------------------------------------------------------------------

# Company phone number displayed in footer and contact sections
# Format: +57 300 123 4567 or similar
NEXT_PUBLIC_COMPANY_PHONE="+57 300 123 4567"

# Company email address for contact display
NEXT_PUBLIC_COMPANY_EMAIL="contacto@asgro.com.co"

# Company physical address
NEXT_PUBLIC_COMPANY_ADDRESS="Calle 100 #19-61, Oficina 802, Bogotá, Colombia"

# ------------------------------------------------------------------------------
# OPTIONAL — AI and Email Services
# (If not set, the AI agent falls back to local keyword matching)
# ------------------------------------------------------------------------------

# OpenAI API key for AI agent responses (optional — enables GPT-powered chat)
OPENAI_API_KEY=""

# Google Gemini API key (alternative to OpenAI, optional)
GEMINI_API_KEY=""

# Resend API key for transactional emails (optional — email notifications)
RESEND_API_KEY=""
